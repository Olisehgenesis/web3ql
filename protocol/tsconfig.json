{
  "compilerOptions": {
    /* Language & emit */
    "target":            "ES2022",
    "module":            "Node16",
    "moduleResolution":  "Node16",
    "lib":               ["ES2022"],
    "outDir":            "dist",
    "rootDir":           ".",
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Strictness */
    "strict":            true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,

    /* Interop / misc */
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":       true
  },
  "include": [
    "compiler/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "hardhat.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "typechain-types",
    "artifacts",
    "cache"
  ]
}
