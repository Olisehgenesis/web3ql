# ════════════════════════════════════════════════════════════════════════════
#  Web3QL — monorepo .gitignore
#  Workspaces: cloud/ (Next.js)  •  protocol/ (Hardhat)  •  sdk/
# ════════════════════════════════════════════════════════════════════════════

# ─── Dependencies ────────────────────────────────────────────────────────────
**/node_modules/
.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
**/.env
**/.env.local
**/.env.*
!**/.env.example       # keep example templates
.env.keys              # dotenvx master decryption key
**/.env.keys
*.pem
*.key
*.p12
*.pfx
*.keystore

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo
**/tsconfig.tsbuildinfo

# Next.js
cloud/.next/
cloud/out/

# ─── Hardhat / Solidity (protocol/) ─────────────────────────────────────────
protocol/artifacts/
protocol/cache/
protocol/typechain-types/
# deployments/ is intentionally tracked (records live contract addresses)

# ─── SDK compiled output ─────────────────────────────────────────────────────
sdk/dist/
sdk/lib/

# ─── Test & coverage ─────────────────────────────────────────────────────────
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/
lcov.info
*.lcov

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ─── Caches ───────────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache/
.turbo/
.cache/
**/.cache/
.swc/

# ─── Vercel / deployment ─────────────────────────────────────────────────────
.vercel
.netlify

# ─── Editor & IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
!.vscode/extensions.json  # keep recommended extensions list if present
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
*.orig

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Temporary / scratch ──────────────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak
*.patch

# ─── Package manager lock files ───────────────────────────────────────────────
# Root uses pnpm workspaces. Sub-packages each have their own pnpm-lock.yaml.
# npm / yarn lock files from accidental installs are noise:
package-lock.json
yarn.lock
