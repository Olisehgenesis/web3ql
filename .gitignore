# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
out/
lib/
*.tsbuildinfo

# ─── Hardhat / Solidity ───────────────────────────────────────────────────────
artifacts/
cache/
typechain-types/
deployments/

# ─── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.*
!.env.example        # allow the template
.env.keys            # dotenvx decryption key

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Test & coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Lock files (keep one, ignore the others) ────────────────────────────────
# Uncomment the lock files you are NOT using:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Editor & OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ─── Temporary files ─────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
