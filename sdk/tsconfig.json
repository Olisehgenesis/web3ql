{
  "compilerOptions": {
    "target"                    : "ES2022",
    "module"                    : "Node16",
    "moduleResolution"          : "Node16",
    "lib"                       : ["ES2022"],
    "outDir"                    : "dist",
    "rootDir"                   : ".",
    "declaration"                : true,
    "declarationMap"             : true,
    "sourceMap"                  : true,
    "esModuleInterop"            : true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule"          : true,
    "strict"                     : true,
    "noUncheckedIndexedAccess"   : true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck"               : true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
